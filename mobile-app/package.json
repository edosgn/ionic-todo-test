{
  "name": "ionic-todo-test",
  "version": "0.0.1",
  "author": "Ionic Framework",
  "homepage": "https://ionicframework.com/",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build && npm run fix-cordova",
    "build:prod": "ng build --configuration production && npm run fix-cordova",
    "copy-www": "rm -rf www/* && cp -r ../dist/ionic-todo-test/* www/",
    "fix-cordova": "node scripts/fix-cordova.js",
    "build:android": "npm run build:prod && cordova build android",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:integration": "npx jest --config jest.config.e2e.ts",
    "test:integration:category": "npx jest --config jest.config.e2e.ts --testPathPattern='category-store.integration'",
    "test:integration:task": "npx jest --config jest.config.e2e.ts --testPathPattern='task-store.integration'",
    "test:integration:cross": "npx jest --config jest.config.e2e.ts --testPathPattern='task-category.integration'",
    "test:bdd": "npx cucumber-js",
    "test:bdd:dry": "npx cucumber-js --profile dry",
    "test:bdd:categories": "npx cucumber-js e2e/features/categories.feature --require e2e/step-definitions/*.steps.ts --require-module ts-node/register",
    "test:bdd:tasks": "npx cucumber-js e2e/features/tasks.feature --require e2e/step-definitions/*.steps.ts --require-module ts-node/register",
    "test:bdd:navigation": "npx cucumber-js e2e/features/navigation.feature --require e2e/step-definitions/*.steps.ts --require-module ts-node/register",
    "test:appium": "npx wdio run e2e/wdio.conf.ts",
    "test:e2e": "npm run test:bdd",
    "test:all": "npm run test:integration && npm run test:bdd",
    "cucumber": "npx cucumber-js",
    "lint": "ng lint"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-browser-dynamic": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@ionic/angular": "^8.0.0",
    "@ionic/cordova-builders": "^12.3.0",
    "firebase": "^11.10.0",
    "ionicons": "^7.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.0.0",
    "@angular-eslint/builder": "^20.0.0",
    "@angular-eslint/eslint-plugin": "^20.0.0",
    "@angular-eslint/eslint-plugin-template": "^20.0.0",
    "@angular-eslint/schematics": "^20.0.0",
    "@angular-eslint/template-parser": "^20.0.0",
    "@angular/cli": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@angular/language-service": "^20.0.0",
    "@ionic/angular-toolkit": "^12.0.0",
    "@types/jasmine": "~5.1.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "autoprefixer": "^10.4.22",
    "cordova-android": "^14.0.1",
    "cordova-ios": "^8.0.0",
    "cordova-plugin-device": "2.0.2",
    "cordova-plugin-firebase": "^2.0.6",
    "cordova-plugin-firebase-analytics": "~6.1.0",
    "cordova-plugin-firebase-config": "^6.0.0",
    "cordova-plugin-ionic-keyboard": "^2.0.5",
    "cordova-plugin-splashscreen": "5.0.2",
    "cordova-plugin-statusbar": "^2.4.2",
    "cordova-support-android-plugin": "~1.0.0",
    "eslint": "^9.16.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^48.2.1",
    "eslint-plugin-prefer-arrow": "1.2.2",
    "jasmine-core": "~5.1.0",
    "jasmine-spec-reporter": "~5.0.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.9.0"
  },
  "description": "An Ionic project",
  "cordova": {
    "plugins": {
      "cordova-plugin-statusbar": {},
      "cordova-plugin-device": {},
      "cordova-plugin-splashscreen": {},
      "cordova-plugin-ionic-keyboard": {},
      "cordova-plugin-firebase-config": {
        "ANDROID_FIREBASE_CONFIG_VERSION": "21.0.+"
      }
    },
    "platforms": [
      "android",
      "ios"
    ]
  }
}